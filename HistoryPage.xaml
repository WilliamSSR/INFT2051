<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CycleWise.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="History">

    <VerticalStackLayout Padding="24" Spacing="16">

        <Label
            Text="History"
            FontSize="24"
            FontAttributes="Bold" />

        <Label
            x:Name="CountLabel"
            Text="Total logs: 0"
            FontSize="14"
            TextColor="Gray" />

        <CollectionView x:Name="LogsCollectionView">
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="8" Padding="0,24,0,0">
                    <Label
                        Text="No records yet."
                        FontSize="18"
                        FontAttributes="Bold" />
                    <Label
                        Text="Go to the Log page and add your first record."
                        FontSize="14"
                        TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1" Padding="16" Margin="0,0,0,12">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="{Binding DateRangeText}"
                                FontAttributes="Bold"
                                FontSize="16" />

                            <Label
                                Text="{Binding SummaryText}"
                                FontSize="14" />

                            <Label
                                Text="{Binding Notes}"
                                FontSize="14"
                                TextColor="Gray" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>