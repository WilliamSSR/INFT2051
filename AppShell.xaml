<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CycleWise.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:CycleWise.Pages"
    FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Home"
            Route="HomePage"
            ContentTemplate="{DataTemplate pages:HomePage}" />

        <ShellContent
            Title="Log"
            Route="LogPage"
            ContentTemplate="{DataTemplate pages:LogPage}" />

        <ShellContent
            Title="History"
            Route="HistoryPage"
            ContentTemplate="{DataTemplate pages:HistoryPage}" />
    </TabBar>
</Shell>
